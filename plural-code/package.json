{
  "name": "plural-code-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "plural-code-core",
    "plural-code-cli",
    "plural-code-desktop",
    "plural-code-docs"
  ],
  "scripts": {
    "core:build": "npm run build --workspace=plural-code-core",
    "cli:start": "npm start --workspace=plural-code-cli",
    "desktop:start": "npm start --workspace=plural-code-desktop",
    "docs:dev": "npm run dev --workspace=plural-code-docs"
  },
  "devDependencies": {
    "electron": "^43.0.0"
  }
}
